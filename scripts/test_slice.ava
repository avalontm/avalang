# Test slicing
local arr = [1, 2, 3, 4, 5]

# Basic slice [1:3]
print("arr[1:3]:", arr[1:3])

# Slice from start [:3]
print("arr[:3]:", arr[:3])

# Slice to end [2:]
print("arr[2:]:", arr[2:])

# Full copy [:]
print("arr[:]:", arr[:])

# Slice with step [::2]
print("arr[::2]:", arr[::2])

# Negative indices [-3:]
print("arr[-3:]:", arr[-3:])

# Slice with start, end, step [1:4:2]
print("arr[1:4:2]:", arr[1:4:2])

# String slicing
local s = "Hello World"

# Basic string slice
print("s[0:5]:", s[0:5])

# String with negative index
print("s[-5:]:", s[-5:])

# String with step
print("s[::2]:", s[::2])