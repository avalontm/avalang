print("=== String Methods ===")
var s = "Hello World"
var u = s.upper()
print("upper: " + u)
var l = s.lower()
print("lower: " + l)
var parts = s.split(" ")
print("split: " + parts)

var t = "  hello  "
var tr = t.trim()
print("trim: '" + tr + "'")

var email = "test@example.com"
var hasAt = email.contains("@")
print("contains '@': " + hasAt)
var idx = email.indexOf("@")
print("indexOf '@': " + idx)
var sw = email.startsWith("test")
print("startsWith 'test': " + sw)
var ew = email.endsWith(".com")
print("endsWith '.com': " + ew)

var r = "hello world".replace("world", "ava")
print("replace: " + r)

print("")
print("=== List Methods ===")
var lst = [1, 2, 3]
lst.append(4)
print("append: " + lst)

var popped = lst.pop()
print("popped: " + popped + ", list: " + lst)

lst.insert(1, 99)
print("insert: " + lst)

var removed = lst.remove(1)
print("removed: " + removed + ", list: " + lst)

print("")
print("=== Dict Methods ===")
var d = {"name": "Alice", "age": 30}
print("keys: " + d.keys())
print("values: " + d.values())
print("containsKey 'name': " + d.containsKey("name"))
print("containsKey 'email': " + d.containsKey("email"))

print("")
print("Done!")
