func counter()
    print("    counter: yielding 1")
    yield 1
    print("    counter: yielding 2")
    yield 2
end

print("Creating fresh coroutine")
co = coroutine(counter)

print("Starting for loop")
count = 0
for n in co do
    print("  Got:", n)
    count = count + 1
    if count >= 2 then
        print("  Breaking after 2 iterations")
        break
    end
end
print("Loop ended, count =", count)
