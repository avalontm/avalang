print("Test 1: Basic try-except")
result = "unknown"
try
    raise "division by zero"
except
    result = "caught exception"
end
print("Result: " + result)

print("\nTest 2: Try-except-finally")
x = 0
try
    x = 10
except
    x = -1
finally
    print("Finally: x = " + str(x))
end

print("\nTest 3: Try with no exception")
result = "ok"
try
    result = "success"
except
    result = "failed"
end
print("Result: " + result)

print("\nAll tests completed!")