# Test Lambda Functions (func expression)

# Basic lambda
double = func(x) return x * 2 end
print(double(5))  # 10

# Lambda with multiple expressions
add = func(a, b) 
    result = a + b
    return result
end
print(add(3, 4))  # 7

# Lambda as argument
func apply(fn, value)
    return fn(value)
end

result = apply(func(x) return x + 10 end, 5)
print(result)  # 15

# Lambda stored in variable
identity = func(x) return x end
print(identity(42))   # 42

print("All lambda tests passed!")