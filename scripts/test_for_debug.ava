print("Step 1: Define counter")
func counter()
    print("  counter: yielding 1")
    yield 1
    print("  counter: yielding 2")
    yield 2
end

print("Step 2: Create coroutine")
co = coroutine(counter)
print("Step 3: First resume")
r1 = resume(co)
print("  Got result: " + str(r1))
print("Step 4: Second resume")
r2 = resume(co)
print("  Got result: " + str(r2))
print("Step 5: Third resume")
r3 = resume(co)
print("  Got result: " + str(r3))
print("Done!")
