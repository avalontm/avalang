# Test Augmented Assignment (+=, -=, *=, /=, %=, **=)

x = 10
x += 5
print(x)  # 15

y = 20
y -= 3
print(y)  # 17

z = 4
z *= 3
print(z)  # 12

w = 20
w /= 4
print(w)  # 5

v = 17
v %= 5
print(v)  # 2

p = 2
p %= 3
print(p)  # 2

# Con listas
list = [1, 2, 3]
list += [4, 5]
print(list)  # [1, 2, 3, 4, 5]

# Con strings
greeting = "Hello"
greeting += " World"
print(greeting)  # Hello World

print("All AugAssign tests passed!")