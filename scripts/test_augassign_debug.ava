# Test AugAssign specifically for list/string concatenation

# Test list concatenation with +
list1 = [1, 2, 3]
list2 = [4, 5]
result = list1 + list2
print(result)  # [1, 2, 3, 4, 5]

# Test list with +=
list3 = [1, 2, 3]
list3 += [4, 5]
print(list3)  # [1, 2, 3, 4, 5]

# Test string concatenation with +
s1 = "Hello"
s2 = " World"
result2 = s1 + s2
print(result2)  # Hello World

# Test string with +=
s3 = "Hello"
s3 += " World"
print(s3)  # Hello World