func simple()
    print("  simple: about to yield 1")
    yield 1
    print("  simple: done yielding")
end

print("Creating coroutine")
co = coroutine(simple)
print("Coroutine created, type:", type(co))

print("Calling resume manually")
result = resume(co)
print("  result:", result)
print("  result type:", type(result))

print("Done!")
