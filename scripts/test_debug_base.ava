class Animal
    func init(nombre)
        print("Animal.init called with: " + nombre)
        this.nombre = nombre
    end
end

class Perro : Animal
    func init(nombre)
        print("Perro.init called, calling base with: " + nombre)
        base(nombre)
        print("Perro.init after base call")
    end
end

print("Creating Perro instance...")
p = Perro("Rex")
print("Instance created")
print("p.nombre = " + p.nombre)