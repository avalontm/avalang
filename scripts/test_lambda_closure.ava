# Test Lambda with closures

# Closure in lambda
func make_multiplier(factor)
    return func(x) return x * factor end end
end

times3 = make_multiplier(3)
times5 = make_multiplier(5)
print(times3(4))  # Expected: 12
print(times5(4))  # Expected: 20

# Lambda returning lambda
func make_adder(n)
    return func(x) return n + x end end
end

add5 = make_adder(5)
print(add5(3))   # Expected: 8
print(add5(10))  # Expected: 15

print("All lambda closure tests passed!")