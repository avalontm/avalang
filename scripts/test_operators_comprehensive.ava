# Comprehensive operator test

# Arithmetic
print(2 + 3)
print(5 - 2)
print(3 * 4)
print(10 / 2)
print(10 % 3)

# List concat
print([1,2] + [3,4])
list_test = [1,2]
list_test += [5,6]
print(list_test)

# String concat
print("Hello" + "World")
s = "Ava"
s += "Lang"
print(s)

# Comparison
print(5 > 3)
print(5 < 3)
print(10 >= 10)
print(5 <= 4)

# Lambda closure
func make_adder(n)
    inner = func(x) return x + n end
    return inner
end

add5 = make_adder(5)
print(add5(10))

print("All tests passed!")